{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/favicon.ico",
      "/manifest.webmanifest",
      "/sw.js",
      "/*.css",
      "/*.js",
      "/*.map",
      "/*.json",
      "/*.webmanifest"
    ]
  },
  "routes": [
    {
      "route": "/auth",
      "rewrite": "/index.html"
    }
  ],
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Cross-Origin-Opener-Policy": "unsafe-none",
    "Cross-Origin-Embedder-Policy": "unsafe-none"
  }
}
